log          = True
jobs         = 10

[template-static-intel]
compiler     = intel
cflags       = $CSTATIC_INT $OPTIMIZE
lflags       = $OPTIMIZE
mod_dir      = ./mod/
obj_dir      = ./obj/
src          = ./src/
exclude_dirs = $EXDIRS
colors       = True
quiet        = False
log          = True
jobs         = 10

[template-shared-intel-debug]
compiler     = intel
cflags       = $CSHARED_INT $DEBUG_INT
lflags       = $LSHARED $DEBUG_INT
mod_dir      = ./mod/
obj_dir      = ./obj/
src          = ./src/
exclude_dirs = $EXDIRS
colors       = True
quiet        = False
log          = True
jobs         = 10

[template-static-intel-debug]
compiler     = intel
cflags       = $CSTATIC_INT $DEBUG_INT
lflags       = $DEBUG_INT
mod_dir      = ./mod/
obj_dir      = ./obj/
src          = ./src/
exclude_dirs = $EXDIRS
colors       = True
quiet        = False
log          = True
jobs         = 10

[rule-delexe]
help = Delete exes
rule = rm -rf exe/

[rule-clean]
help = Clean the project tree
rule_1 = FoBiS.py rule -ex deldoc
rule_2 = FoBiS.py rule -ex delexe
rule_3 = rm -f *.gcov

[rule-makedoc]
help   = Build documentation with formal + VitePress
rule_1 = formal generate --mirror-sources --diagrams --project docs/ford.md --output docs/api
rule_2 = cd docs && npm ci && npm run docs:build

[rule-deldoc]
help = Delete documentation build artifacts
rule = rm -rf docs/.vitepress/dist/ docs/.vitepress/cache/ docs/api/

[rule-maketar]
help = Rule for making tar archive of the project
rule = tar --xform="s%^%VTKFortran/%" -czf VTKFortran.tar.gz *

[rule-makecoverage]
help   = Rule for performing coverage analysis
rule_1 = FoBiS.py rule -ex delexe
rule_2 = FoBiS.py build -mode tests-gnu-debug -coverage
rule_3 = ./scripts/run_tests.sh
rule_4 = rm -f exe/obj/befor64* exe/obj/face* exe/obj/foxy* exe/obj/penf* exe/obj/stringifor*
rule_5 = ./scripts/compute-coverage.sh

[rule-maketests-zlib]
help   = Build and run tests with VTKFORTRAN_USE_ZLIB enabled (no coverage).
rule_1 = FoBiS.py clean -mode tests-gnu-debug-zlib
rule_2 = FoBiS.py build -mode tests-gnu-debug-zlib
rule_3 = ./scripts/run_tests.sh

[rule-makecoverage-analysis]
help   = Rule for performing coverage analysis and saving reports in markdown
rule_1 = FoBiS.py rule -ex makecoverage
rule_2 = FoBiS.py rule -gcov_analyzer docs/guide/ coverage-analysis
rule_3 = rm -f *.gcov
